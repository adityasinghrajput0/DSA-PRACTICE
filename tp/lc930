//prefix sum approach
class Solution {
public:
    int numSubarraysWithSum(vector<int>& nums, int goal) {
        unordered_map<int,int> hash;
        int presum=0,cnt=0;
        for (int i=0; i<nums.size(); i++) {
            presum+=nums[i];
            if (presum==goal) cnt++;
            int rem=presum-goal;
            if (hash.find(rem)!=hash.end()) cnt+=hash[rem];
            hash[presum]++;
        }
        return cnt;
    }
};


//tp approach

//main idea is to calculate the number of subarrays where the sum is <=goal and subtract it from subarrays where sum is <goal;
class Solution {
public:
    int atMost(vector<int>& nums,int goal) {
        int left=0,right=0;
        int cnt=0,sum=0;
        if (goal<0) return 0;
        while (right<nums.size()) {
            sum+=nums[right];
            while (sum>goal) {
                sum-=nums[left];
                left++;
            }
            cnt+=(right-left+1);
            right++;
        }
        return cnt;
    }
    int numSubarraysWithSum(vector<int>& nums, int goal) {
        
        return atMost(nums,goal)-atMost(nums,goal-1);
    }
};