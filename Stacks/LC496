class Solution
{
public:
    vector<int> nextGreaterElement(vector<int> &nums1, vector<int> &nums2)
    {
        stack<int> st;                // store elements in decreasing order(monotonic stack)
        unordered_map<int, int> hash; // mapping each element with its nge;
        vector<int> res;
        for (int i = nums2.size() - 1; i >= 0; i--)
        {
            int nge = -1; // default nge -1
            while (!st.empty() && st.top() < nums2[i])
                st.pop(); // if stack consits of elements lesser than curr pop till it finds greater ele;
            if (!st.empty())
                nge = st.top();
            st.push(nums2[i]);
            hash[nums2[i]] = nge;
        }
        for (int x : nums1)
        {
            res.push_back(hash[x]);
        }
        return res;
    }
};