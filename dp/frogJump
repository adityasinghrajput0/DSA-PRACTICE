class Solution {
  public:
    int minCost(vector<int>& height) {
        // Code here
        int n=height.size();
        if (n==1) return 0;
        vector<int> dp(n,-1);
        int prev1=0;
        int prev2=abs(height[1]-height[0]);
        
        for (int i=2; i<n; i++) {
            int curri=min(prev1+abs(height[i]-height[i-2]),prev2+abs(height[i]-height[i-1]));
            prev1=prev2;
            prev2=curri;
        }
        return prev2;
    }
};