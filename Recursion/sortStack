class Solution {
  public:
    void insert(stack<int> &st,int x) {//Insert the element at right place using recursion
        if (st.empty() || x>st.top()) {
            st.push(x);
            return;
        }
        
        int temp=st.top();
        st.pop();
        insert(st,x);
        st.push(temp);
    }
    void sortStack(stack<int> &st) {//using this function to divide stack into different nums.
        // code here
        if (st.empty()) return;
        int x=st.top();
        st.pop();
        
        sortStack(st);
        insert(st,x);
        
    }
};
